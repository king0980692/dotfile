# Ignore everything by default
*

# Track these config directories
!.gitignore
!.gitconfig
!starship.toml
!install.sh
!uninstall.sh
!README.md

!bash/
!bash/**

!nvim/
!nvim/**

!mise/
!mise/**

!tmux/
!tmux/**
# Ignore tmux plugin repos (will be auto-installed)
tmux/plugins/

!leon_scripts/
!leon_scripts/**

!lazygit/
!lazygit/**

!yazi/
!yazi/**
# Ignore yazi plugin repos
yazi/plugins/

!git/
!git/**

!nix-darwin/
!nix-darwin/**

!karabiner/
!karabiner/**
karabiner/automatic_backups/

!skhd/
!skhd/**

!yabai/
!yabai/**

!ghostty/
!ghostty/**

# herdr: track config + scripts + our local plugin only. Everything else in
# herdr/ (logs, sockets, session*.json, plugins.json, release-notes, the
# auto-installed github/config plugins, sessions/, the resurrect/ output dir)
# stays ignored by the default `*` rule.
!herdr/
!herdr/config.toml
!herdr/scripts/
!herdr/scripts/**
!herdr/plugins/
!herdr/plugins/local/
!herdr/plugins/local/**
# ...but not python bytecode
herdr/scripts/**/__pycache__/

# systemd user units (herdr-resurrect save timer)
!systemd/
!systemd/**
